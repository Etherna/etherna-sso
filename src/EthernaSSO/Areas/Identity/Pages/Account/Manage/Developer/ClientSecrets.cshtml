@page "{id}"
@model Etherna.SSOServer.Areas.Identity.Pages.Account.Manage.Developer.ClientSecretsModel
@{
    ViewData["Title"] = "Client Secrets";
    ViewData["ActivePage"] = ManageNavPages.Developer;
}

<div class="row">
    <div class="col-12 mb-3 text-center mt-1">
        <h2>@ViewData["Title"]</h2>
        <p class="text-muted">@Model.ClientName (@Model.ClientId)</p>
    </div>
</div>

<partial name="_StatusMessage" model="Model.StatusMessage" />

<form id="client-secrets-form" method="post" asp-route-id="@Model.Id">
    <div class="row">
        <div class="col-md-12">

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="card mt-3">
                <h5 class="card-header">Add New Secret</h5>
                <div class="card-body">

                    <div class="mb-3 row">
                        <label asp-for="Input.Description" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" asp-for="Input.Description" />
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label asp-for="Input.Expiration" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input type="datetime-local" class="form-control" asp-for="Input.Expiration" />
                            <span asp-validation-for="Input.Expiration" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 row">
                        <label class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <button type="submit" class="btn btn-primary">Add Secret</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="row">
    <div class="col-md-12">
        <div class="card mt-3">
            <h5 class="card-header">Existing Secrets</h5>
            <div class="card-body">

                <div class="row table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th>Created</th>
                                <th>Expiration</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var secret in Model.Secrets)
                            {
                                <tr>
                                    <td class="align-middle">@secret.Description</td>
                                    <td class="align-middle">@secret.Created.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td class="align-middle">@secret.Expiration?.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td class="align-middle">
                                        @if (secret.IsExpired)
                                        {
                                            <span class="badge bg-danger">Expired</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        <form method="post" asp-page-handler="DeleteSecret"
                                              asp-route-id="@Model.Id"
                                              asp-route-secretHash="@secret.HashedValue"
                                              style="display:inline">
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <a asp-page="ClientEdit" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Client</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
