@page "{id}"
@model Etherna.SSOServer.Areas.Identity.Pages.Account.Manage.Developer.ClientDeleteModel
@{
    ViewData["Title"] = "Delete Client";
    ViewData["ActivePage"] = ManageNavPages.Developer;
}

<div class="row">
    <div class="col-12 mb-3 text-center mt-1">
        <h2>@ViewData["Title"]</h2>
    </div>
</div>

<form id="client-form" asp-page-handler="Delete" asp-route-id="@Model.Id" method="post">

    <div class="card mt-3">
        <h5 class="card-header">Confirm Deletion</h5>
        <div class="card-body">

            <p class="text-danger fw-bold">Are you sure you want to delete this client? This action cannot be undone.</p>

            <div class="mb-3 row">
                <label asp-for="ClientId" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input type="text" class="form-control" disabled asp-for="ClientId" />
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="ClientName" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input type="text" class="form-control" disabled asp-for="ClientName" />
                </div>
            </div>

            <div class="mb-3 row">
                <div class="col-sm-9 offset-sm-3">
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    <a asp-page="ClientEdit" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>
