@page
@model Etherna.SSOServer.Areas.Identity.Pages.Account.Manage.Developer.ClientCreateModel
@{
    ViewData["Title"] = "Create Client Application";
    ViewData["ActivePage"] = ManageNavPages.Developer;
}

<h4>@ViewData["Title"]</h4>
<partial name="_StatusMessage" for="StatusMessage" />

@if (Model.GeneratedClientId is not null)
{
    <div class="card border-success mb-4">
        <div class="card-header bg-success text-white">
            <strong>Application Created Successfully</strong>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-bold">Client ID</label>
                <div class="input-group">
                    <input type="text" class="form-control" value="@Model.GeneratedClientId" readonly id="clientIdField" />
                    <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('clientIdField')">Copy</button>
                </div>
            </div>

            @if (Model.GeneratedSecret is not null)
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Client Secret</label>
                    <div class="input-group">
                        <input type="text" class="form-control" value="@Model.GeneratedSecret" readonly id="clientSecretField" />
                        <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('clientSecretField')">Copy</button>
                    </div>
                    <div class="alert alert-warning mt-2 mb-0">
                        <strong>Save this secret now.</strong> It will not be shown again. If you lose it, you will need to generate a new one.
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <form id="client-create-form" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @* Step 1: Choose application type *@
        <div class="card mb-4">
            <div class="card-header">
                <strong>Step 1:</strong> Choose application type
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" asp-for="Input.ClientType"
                               value="@ClientAppType.WebApp" id="typeWebApp" />
                        <label class="form-check-label fw-bold" for="typeWebApp">
                            Web Application
                        </label>
                        <div class="text-muted small">
                            Server-side web application (e.g., ASP.NET, Django, Express).
                            Uses Authorization Code flow. A client secret is generated for secure server-to-server communication.
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" asp-for="Input.ClientType"
                               value="@ClientAppType.NativeApp" id="typeNativeApp" />
                        <label class="form-check-label fw-bold" for="typeNativeApp">
                            Native Application
                        </label>
                        <div class="text-muted small">
                            Desktop, mobile, or single-page application that runs on the user's device.
                            Uses Authorization Code with PKCE for security without a shared secret.
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" asp-for="Input.ClientType"
                               value="@ClientAppType.ClientCredential" id="typeClientCredential" />
                        <label class="form-check-label fw-bold" for="typeClientCredential">
                            Machine-to-Machine
                        </label>
                        <div class="text-muted small">
                            Backend service or daemon that accesses APIs without user interaction.
                            Uses Client Credentials flow with a client secret.
                        </div>
                    </div>

                    <span asp-validation-for="Input.ClientType" class="text-danger"></span>
                </div>
            </div>
        </div>

        @* Step 2: Application details *@
        <div class="card mb-4">
            <div class="card-header">
                <strong>Step 2:</strong> Application details
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Input.ClientName" class="form-label"></label>
                    <input asp-for="Input.ClientName" class="form-control" />
                    <span asp-validation-for="Input.ClientName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label"></label>
                    <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                    <div class="form-text">Optional. A brief description of your application.</div>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>
            </div>
        </div>

        @* Step 3: Configuration *@
        <div class="card mb-4">
            <div class="card-header">
                <strong>Step 3:</strong> Configuration
            </div>
            <div class="card-body">
                <div class="mb-3" id="redirectUrisGroup">
                    <label asp-for="Input.RedirectUris" class="form-label"></label>
                    <textarea asp-for="Input.RedirectUris" class="form-control" rows="3"></textarea>
                    <div class="form-text">
                        One URI per line. These are the URLs where users will be redirected after authentication.
                        Required for Web Application and Native Application types.
                    </div>
                    <span asp-validation-for="Input.RedirectUris" class="text-danger"></span>
                </div>

                <div class="mb-3" id="postLogoutRedirectUrisGroup">
                    <label asp-for="Input.PostLogoutRedirectUris" class="form-label"></label>
                    <textarea asp-for="Input.PostLogoutRedirectUris" class="form-control" rows="3"></textarea>
                    <div class="form-text">
                        One URI per line. Optional. URLs where users will be redirected after logging out.
                    </div>
                    <span asp-validation-for="Input.PostLogoutRedirectUris" class="text-danger"></span>
                </div>

                <div class="mb-3" id="allowedCorsOriginsGroup">
                    <label asp-for="Input.AllowedCorsOrigins" class="form-label"></label>
                    <textarea asp-for="Input.AllowedCorsOrigins" class="form-control" rows="3"></textarea>
                    <div class="form-text">
                        One URI per line. Required for Native Application (browser-based apps).
                        Origins allowed for cross-origin requests.
                    </div>
                    <span asp-validation-for="Input.AllowedCorsOrigins" class="text-danger"></span>
                </div>
            </div>
        </div>

        @* Step 4: Scopes *@
        <div class="card mb-4">
            <div class="card-header">
                <strong>Step 4:</strong> Scopes
            </div>
            <div class="card-body">
                <h6>Identity Scopes</h6>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="openid"
                               checked disabled id="scopeOpenid" />
                        <input type="hidden" name="Input.AllowedScopes" value="openid" />
                        <label class="form-check-label" for="scopeOpenid">
                            openid <span class="text-muted small">(always required)</span>
                        </label>
                    </div>
                    @foreach (var scope in ClientApp.DeveloperAllowedIdentityScopes.Where(s => s != "openid"))
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Input.AllowedScopes"
                                   value="@scope" id="scope_@scope"
                                   @(Model.Input.AllowedScopes.Contains(scope) ? "checked" : "") />
                            <label class="form-check-label" for="scope_@scope">
                                @scope
                            </label>
                        </div>
                    }
                </div>

                <h6>API Scopes</h6>
                <div class="mb-3">
                    @foreach (var scope in ClientApp.DeveloperAllowedApiScopes)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Input.AllowedScopes"
                                   value="@scope" id="scope_@scope.Replace(".", "_")"
                                   @(Model.Input.AllowedScopes.Contains(scope) ? "checked" : "") />
                            <label class="form-check-label" for="scope_@scope.Replace(".", "_")">
                                @scope
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg">Create Application</button>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function copyToClipboard(elementId) {
            var field = document.getElementById(elementId);
            navigator.clipboard.writeText(field.value).then(function () {
                var btn = field.nextElementSibling;
                var originalText = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(function () { btn.textContent = originalText; }, 2000);
            });
        }

        (function () {
            var radios = document.querySelectorAll('input[name="Input.ClientType"]');
            var redirectGroup = document.getElementById('redirectUrisGroup');
            var postLogoutGroup = document.getElementById('postLogoutRedirectUrisGroup');
            var corsGroup = document.getElementById('allowedCorsOriginsGroup');

            function updateVisibility() {
                var selected = document.querySelector('input[name="Input.ClientType"]:checked');
                if (!selected) {
                    // Show all groups by default when nothing is selected.
                    if (redirectGroup) redirectGroup.style.display = '';
                    if (postLogoutGroup) postLogoutGroup.style.display = '';
                    if (corsGroup) corsGroup.style.display = '';
                    return;
                }

                var value = selected.value;
                // WebApp
                if (value === '@ClientAppType.WebApp') {
                    if (redirectGroup) redirectGroup.style.display = '';
                    if (postLogoutGroup) postLogoutGroup.style.display = '';
                    if (corsGroup) corsGroup.style.display = 'none';
                }
                // NativeApp
                else if (value === '@ClientAppType.NativeApp') {
                    if (redirectGroup) redirectGroup.style.display = '';
                    if (postLogoutGroup) postLogoutGroup.style.display = '';
                    if (corsGroup) corsGroup.style.display = '';
                }
                // ClientCredential
                else if (value === '@ClientAppType.ClientCredential') {
                    if (redirectGroup) redirectGroup.style.display = 'none';
                    if (postLogoutGroup) postLogoutGroup.style.display = 'none';
                    if (corsGroup) corsGroup.style.display = 'none';
                }
            }

            if (radios) {
                radios.forEach(function (radio) {
                    radio.addEventListener('change', updateVisibility);
                });
                updateVisibility();
            }
        })();
    </script>
}
