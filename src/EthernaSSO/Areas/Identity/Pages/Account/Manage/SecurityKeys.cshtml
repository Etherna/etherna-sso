@page
@model SecurityKeysModel
@{
    ViewData["Title"] = "Manage security key";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h2>@ViewData["Title"]</h2>

<dl class="row">
    <dt class="col-sm-3">Current name</dt>
    <dd class="col-sm-9">@Model.Credential.Nickname</dd>
    <dt class="col-sm-3">Registered</dt>
    <dd class="col-sm-9">@Model.Credential.CreatedAt.ToString("u")</dd>
    <dt class="col-sm-3">Last used</dt>
    <dd class="col-sm-9">@(Model.Credential.LastUsedAt?.ToString("u") ?? "never")</dd>
</dl>

<h4>Rename</h4>
<div class="row">
    <div class="col-md-6">
        <form method="post" asp-page-handler="Rename">
            <input type="hidden" asp-for="Input.CredentialId" value="@Model.CredentialIdBase64" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Input.Nickname"></label>
                <input asp-for="Input.Nickname" class="form-control" maxlength="@Etherna.SSOServer.Domain.Models.Fido2CredentialAgg.Fido2Credential.MaxNicknameLength" />
                <span asp-validation-for="Input.Nickname" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="./TwoFactorAuthentication" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>

<hr />

<h4>Remove</h4>
@if (Model.IsLastFactor)
{
    <div class="alert alert-warning" role="alert">
        <strong>This is your only second factor.</strong>
        Removing it will turn off two-factor authentication for your account.
    </div>
}
<form method="post" asp-page-handler="Remove">
    <input type="hidden" asp-for="Input.CredentialId" value="@Model.CredentialIdBase64" />
    <input type="hidden" asp-for="Input.Nickname" value="@Model.Credential.Nickname" />
    <button type="submit" class="btn btn-danger" onclick="return confirm('Remove this security key? You will no longer be able to use it to sign in.');">Remove security key</button>
</form>
