@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h4>@ViewData["Title"]</h4>
<partial name="_StatusMessage" model="Model.StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <div asp-validation-summary="All" class="text-danger"></div>

        <form id="verification-form" method="post">
            <div class="mb-3">
                <label asp-for="Email"></label>
                <div class="input-group">
                    <input asp-for="Email" class="form-control" disabled />
                </div>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <button id="remove-email-button" type="submit" asp-page-handler="RemoveEmail" class="btn btn-link">Remove email</button>
                }
            </div>
        </form>

        <form id="email-form" method="post">
            <div class="mb-3">
                <label asp-for="Input.NewEmail"></label>
                <input asp-for="Input.NewEmail" class="form-control" />
                <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
            </div>
            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn btn-primary">Change email</button>
        </form>
    </div>
</div>
