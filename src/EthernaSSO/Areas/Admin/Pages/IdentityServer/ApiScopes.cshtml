@page
@model Etherna.SSOServer.Areas.Admin.Pages.IdentityServer.ApiScopesModel
@{
    ViewData["Title"] = "API Scopes";
}

<div class="row">
    <div class="col-12 mb-3 text-center mt-1">
        <h2>@ViewData["Title"]</h2>
    </div>
</div>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Admin</a></li>
        <li class="breadcrumb-item active" aria-current="page">API Scopes</li>
    </ol>
</nav>

<div class="alert alert-info" role="alert">
    These scopes are defined in the server configuration and cannot be modified from this interface.
</div>

<div class="row">
    <div class="col-12">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Display Name</th>
                        <th>Description</th>
                        <th>Required</th>
                        <th>Emphasize</th>
                        <th>Enabled</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var scope in Model.ApiScopes)
                    {
                        <tr>
                            <td class="align-middle">@scope.Name</td>
                            <td class="align-middle">@scope.DisplayName</td>
                            <td class="align-middle">@scope.Description</td>
                            <td class="align-middle">
                                @if (scope.Required)
                                {
                                    <span class="badge bg-warning">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="align-middle">
                                @if (scope.Emphasize)
                                {
                                    <span class="badge bg-warning">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="align-middle">
                                @if (scope.Enabled)
                                {
                                    <span class="badge bg-success">Enabled</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Disabled</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
