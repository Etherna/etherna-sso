@page
@model StatusCodeModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center" style="margin-top: 5rem; margin-bottom: 5rem;">
    <div class="col-lg-6 col-md-8 text-center">
        <div class="error-code" aria-hidden="true">@Model.Code</div>
        <h1 class="h2 fw-semibold mb-3">@Model.Title</h1>
        <p class="text-muted mb-5 fs-5">@Model.Description</p>
        <a asp-page="/Index" class="btn btn-primary px-4 py-2">Back to home</a>
    </div>
</div>

@section Scripts {
    <style>
        .error-code {
            font-size: clamp(5rem, 18vw, 10rem);
            font-weight: 800;
            line-height: 1;
            color: #e9ecef;
            letter-spacing: -0.02em;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, #dee2e6 0%, #adb5bd 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
}
