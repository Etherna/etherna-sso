@model ConfirmEmailChangeModel

@{
    ViewData["EmailTitle"] = ConfirmEmailChangeModel.Title;
}

<h1>@ConfirmEmailChangeModel.Title</h1>

<p>Please confirm your email change by clicking here:</p>
<a class="button" href='@Model.CallbackUrl'>Confirm email</a>

<p style="margin-top: 32px">or copy/pasting this url:</p>
<p>@Model.CallbackUrl</p>